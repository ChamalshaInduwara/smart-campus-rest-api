            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"sensor-invalid-room\",\n  \"type\": \"{{sensorType}}\",\n  \"status\": \"ACTIVE\",\n  \"currentValue\": 0.0,\n  \"roomId\": \"room-does-not-exist\"\n}"
            },
            "url": "{{baseUrl}}/sensors"
          },
          "response": []

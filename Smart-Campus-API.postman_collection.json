    {
      "name": "Error Cases",
      "item": [
        {
          "name": "POST sensor with invalid roomId (expect 422 or 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 400 or 422\", function () {",
                  "    pm.expect([400, 422]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
